ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-11.8/bin/nvcc

cflags = -pthread -B /usr/local/anaconda3/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /usr/local/anaconda3/include -I/usr/local/anaconda3/include -fPIC -O2 -isystem /usr/local/anaconda3/include -fPIC -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/TH -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/usr/local/anaconda3/include/python3.9 -c
post_cflags = -g -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1013"' -DTORCH_EXTENSION_NAME=emd_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/TH -I/usr/local/anaconda3/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/usr/local/anaconda3/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O2 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1013"' -DTORCH_EXTENSION_NAME=emd_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



build /home/dyxue/duedunyao/Point-MAE-main/extensions/emd/build/temp.linux-x86_64-3.9/cuda/emd.o: compile /home/dyxue/duedunyao/Point-MAE-main/extensions/emd/cuda/emd.cpp
build /home/dyxue/duedunyao/Point-MAE-main/extensions/emd/build/temp.linux-x86_64-3.9/cuda/emd_kernel.o: cuda_compile /home/dyxue/duedunyao/Point-MAE-main/extensions/emd/cuda/emd_kernel.cu





